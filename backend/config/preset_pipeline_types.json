  "vlm": [
    {
      "id": "signature",
      "name": "签字",
      "description": "用视觉语言模型识别手写签名、签字姓名和签署区域内的有效签名笔迹。",
      "examples": [
        "合同末页签字",
        "手写姓名",
        "签署栏姓名"
      ],
      "color": "#2563EB",
      "enabled": true,
      "order": 10,
      "rules": [
        "识别真实可见的手写签名、签字姓名和签署栏中的有效签名笔迹。",
        "只框住实际手写签名字迹，不要框整行手写说明、空白栏、表格背景、横线或印刷标题。",
        "同一处签字只输出一个紧贴笔迹边缘的框；多处签字分别输出。"
      ],
      "checklist": [
        {
          "rule": "手写签名或手写姓名",
          "positive_prompt": "能看到自然手写笔迹，例如中文姓名、英文签名、草写签名、签署栏内手写姓名；框必须贴住笔迹本身。",
          "negative_prompt": "打印体姓名、OCR 文本、表格中的预填姓名、仅有“签字/签名/经办人/日期”等印刷标签时不要输出。"
        },
        {
          "rule": "签署区域内的有效签名笔迹",
          "positive_prompt": "在签署、确认、审批、经办等区域内，存在短的手写姓名、草签、签名缩写或与签名紧贴的日期时可以输出。",
          "negative_prompt": "整句手写说明、普通正文批注、页眉页脚、问答记录、金额百分比、合同条款中的手写或印刷内容不要当作签字输出。"
        },
        {
          "rule": "边界与数量控制",
          "positive_prompt": "每一处独立签字或签署笔迹单独输出一个紧贴框；淡色、局部遮挡、压在印章附近但仍能看出手写笔迹的也可以输出。",
          "negative_prompt": "不要框空白签署栏、下划线、表格边框、印章、指纹、红色手印、二维码、logo、水印、涂抹阴影或整块签署区域。"
        }
      ],
      "negative_prompt_enabled": true,
      "negative_prompt": "没有实际手写笔迹时不要输出；打印体、印章、指纹、红色手印、空白签署栏、仅有横线或表格边框、仅有字段标签、整句手写说明、整段正文和整块签署区域都不是签字。",
      "few_shot_enabled": false,
      "few_shot_samples": []
    }
  ]
