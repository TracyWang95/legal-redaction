# ============================================================
# DataInfra-RedactionEverything Docker Compose environment variables
# Copy this file to .env when using docker compose.
# For local npm-run development, copy .env.example instead.
# Default Docker start (`docker compose up -d`) is lightweight UI/API smoke mode:
# it publishes the browser entry on http://localhost:3000 and does not start
# OCR, HaS Text, or HaS Image. Full recognition requires the GPU profile:
# docker compose --profile gpu up -d
# ============================================================

# ---------- Basics ----------
DEBUG=false                          # true / false
# APP_NAME=DataShield Redaction Infrastructure

# ---------- Authentication ----------
# PRODUCTION WARNING: keep AUTH_ENABLED=true for any non-local deployment.
AUTH_ENABLED=true                    # Disable only for isolated local debugging
# Local eval/automation can authenticate with one of these without storing
# browser cookies. Never commit real values.
# DATAINFRA_PASSWORD=
# DATAINFRA_TOKEN=
# DATAINFRA_TOKEN_FILE=
# JWT_SECRET_KEY=                    # Leave empty to auto-generate and persist under DATA_DIR
# NOTE (Windows): for production, prefer an explicit environment variable instead
# of relying on a file-persisted secret.
# JWT_EXPIRE_MINUTES=1440            # Token lifetime in minutes (default: 24h)

# ---------- Directories inside the container ----------
DATA_DIR=/app/data
UPLOAD_DIR=/app/uploads
OUTPUT_DIR=/app/outputs

# ---------- File limits ----------
# MAX_FILE_SIZE=52428800             # Maximum upload size in bytes (default: 50 MB)

# ---------- Service endpoints ----------
# Docker internal network:
OCR_BASE_URL=http://ocr:8082
HAS_LLAMACPP_BASE_URL=http://ner:8080/v1
HAS_IMAGE_BASE_URL=http://vision:8081

# ---------- Published ports ----------
# Keep 3000 as the single default browser entry.
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ---------- Timeouts in seconds ----------
# OCR_TIMEOUT=360
# OCR_MAX_NEW_TOKENS=1024              # Lower to 512 for speed, raise for dense scanned pages
# HAS_TIMEOUT=120
# HAS_IMAGE_TIMEOUT=120
# BATCH_RECOGNITION_PAGE_TIMEOUT=180
# BATCH_RECOGNITION_PAGE_CONCURRENCY=1   # Use 2 only after measuring on larger GPUs
# VISION_DUAL_PIPELINE_PARALLEL=false    # Use true only when OCR and HaS Image do not contend for the same GPU

# ---------- Redaction output ----------
# REDACTION_PDF_JPEG_QUALITY=88           # Scanned PDF page raster quality, clamped to 60-95

# ---------- Evaluation gates ----------
# EVAL_BATCH_MIN_FILE_DETECTIONS=1        # Per completed file: entities + bounding boxes
# EVAL_BATCH_MIN_TOTAL_DETECTIONS=        # Default is the input file count
# EVAL_BATCH_MIN_TOTAL_ENTITIES=0
# EVAL_BATCH_MIN_TOTAL_BOXES=0
# EVAL_BATCH_MAX_PDF_SIZE_RATIO=8         # Fail redacted PDFs above original-size multiple
# EVAL_BATCH_MAX_PDF_SIZE_BYTES=20971520  # Fail redacted PDFs above 20 MiB
# EVAL_BATCH_WARN_PDF_SIZE_RATIO=4        # Mark delivery risk above original-size multiple
# EVAL_BATCH_WARN_PDF_SIZE_BYTES=10485760 # Mark delivery risk above 10 MiB

# ---------- PaddleOCR device ----------
# OCR_REQUIRE_GPU=false              # Reject CPU fallback instead of running slowly
# Model/GPU services are optional for UI/API smoke. Enable them only when local
# model files and NVIDIA container runtime are available:
#   docker compose --profile gpu up -d
# Model file layout for GPU services: docs/MODELS.md

# ---------- CORS ----------
# CORS_ORIGINS=["http://localhost:3000"]   # JSON array format
# Production example:
# CORS_ORIGINS=["https://your-domain.com"]
# Multiple origins example:
# CORS_ORIGINS=["https://app.example.com","https://admin.example.com"]
# WARNING: do not use ["*"] in production.

# ---------- Optional security ----------
# PRODUCTION WARNING: enable encryption and virus scanning for sensitive data.
# FILE_ENCRYPTION_ENABLED=false      # AES-256-GCM at-rest encryption
# VIRUS_SCAN_ENABLED=false           # Requires a ClamAV daemon

# ---------- Redaction ----------
# DEFAULT_REPLACEMENT_MODE=smart     # smart / mask / custom
