# ============================================================
# DataInfra-RedactionEverything — Docker 部署环境变量
# 复制为 .env 后按需修改；未设置的变量使用括号内的默认值。
# ============================================================

# ---------- 基础 ----------
DEBUG=false                          # true / false
# APP_NAME=DataShield 匿名化数据基础设施

# ---------- 认证 ----------
AUTH_ENABLED=false                   # 启用后需设置密码（首次访问 /setup）
# JWT_SECRET_KEY=                    # 留空则自动生成并持久化到 data 目录
# NOTE (Windows): File-based auto-generated secrets have limited OS-level protection
# on Windows. For production, set this explicitly via environment variable rather
# than relying on file persistence. Use a strong random value (e.g., `openssl rand -hex 32`).
# 注意（Windows）：Windows 文件系统对自动生成密钥的保护有限，生产环境建议通过环境变量显式设置。
# JWT_EXPIRE_MINUTES=1440            # Token 过期时间（分钟），默认 24h

# ---------- 目录（容器内路径，通过 volume 持久化）----------
DATA_DIR=/app/data
UPLOAD_DIR=/app/uploads
OUTPUT_DIR=/app/outputs

# ---------- 文件限制 ----------
# MAX_FILE_SIZE=52428800             # 最大上传文件大小（字节），默认 50MB

# ---------- 微服务地址（Docker 内部网络）----------
OCR_BASE_URL=http://ocr:8082
HAS_LLAMACPP_BASE_URL=http://ner:8080/v1
HAS_IMAGE_BASE_URL=http://vision:8081

# ---------- 超时（秒）----------
# OCR_TIMEOUT=360                    # PaddleOCR VL 推理超时
# HAS_TIMEOUT=120                    # HaS Text NER 超时
# HAS_IMAGE_TIMEOUT=120              # HaS Image YOLO 超时

# ---------- PaddleOCR 设备 ----------
# OCR_REQUIRE_GPU=false              # true: 拒绝 CPU 推理，OCR 服务不可用时直接报错而非超慢回退
                                     # 启用 GPU 服务：docker compose --profile gpu up -d
                                     # true: reject CPU inference — fail fast instead of slow fallback
                                     # Enable GPU services: docker compose --profile gpu up -d

# ---------- CORS ----------
# CORS_ORIGINS=["http://localhost:3000"]   # JSON 数组格式
# Production: set to your actual domain(s), e.g.:
#   CORS_ORIGINS=["https://your-domain.com"]
# Multiple origins: CORS_ORIGINS=["https://app.example.com","https://admin.example.com"]
# WARNING: Do NOT use ["*"] in production — it disables browser CORS protection.
# 生产环境请设置为实际域名，不要使用通配符 ["*"]。

# ---------- 安全（可选）----------
# FILE_ENCRYPTION_ENABLED=false      # AES-256-GCM 加密落盘
# VIRUS_SCAN_ENABLED=false           # 需配合 ClamAV daemon

# ---------- 匿名化 ----------
# DEFAULT_REPLACEMENT_MODE=smart     # smart / mask / custom
