# ============================================================
# DataInfra-RedactionEverything Docker environment variables
# Copy this file to .env and adjust values as needed.
# ============================================================

# ---------- Basics ----------
DEBUG=false                          # true / false
# APP_NAME=DataShield Redaction Infrastructure

# ---------- Authentication ----------
# PRODUCTION WARNING: keep AUTH_ENABLED=true for any non-local deployment.
AUTH_ENABLED=true                    # Disable only for isolated local debugging
# JWT_SECRET_KEY=                    # Leave empty to auto-generate and persist under DATA_DIR
# NOTE (Windows): for production, prefer an explicit environment variable instead
# of relying on a file-persisted secret.
# JWT_EXPIRE_MINUTES=1440            # Token lifetime in minutes (default: 24h)

# ---------- Directories inside the container ----------
DATA_DIR=/app/data
UPLOAD_DIR=/app/uploads
OUTPUT_DIR=/app/outputs

# ---------- File limits ----------
# MAX_FILE_SIZE=52428800             # Maximum upload size in bytes (default: 50 MB)

# ---------- Service endpoints ----------
# Docker internal network:
OCR_BASE_URL=http://ocr:8082
HAS_LLAMACPP_BASE_URL=http://ner:8080/v1
HAS_IMAGE_BASE_URL=http://vision:8081
# Local development (without Docker):
# OCR_BASE_URL=http://127.0.0.1:8082
# HAS_LLAMACPP_BASE_URL=http://127.0.0.1:8080/v1
# HAS_IMAGE_BASE_URL=http://127.0.0.1:8081

# ---------- Local npm dev profile ----------
# The open-source dev entry is intentionally small:
#   npm run dev
#   npm run stop
#
# Windows runs the frontend/backend, HaS Image and llama.cpp VLM. WSL runs the
# two vLLM endpoints and the lightweight OCR wrapper so PaddleOCR stays in the
# same CUDA Python environment.
# WINDOWS_VENV_DIR=.venv
# VLLM_VENV_DIR=/home/YOUR_USER/.cache/datainfra-redaction/.venv-vllm
#
# PaddleOCR-VL via vLLM in WSL:
# OCR_VL_BACKEND=vllm-server
# OCR_VLLM_URL=http://127.0.0.1:8118/v1
# OCR_VL_API_MODEL_NAME=PaddleOCR-VL-1.5-0.9B
# VLLM_EXTRA_ARGS=--max-model-len 4096 --gpu-memory-utilization 0.34
#
# HaS Text via vLLM in WSL:
# HAS_TEXT_RUNTIME=vllm
# HAS_TEXT_HF_MODEL_PATH=/mnt/d/path/to/HaS_4.0_0.6B
# HAS_TEXT_MODEL_NAME=HaS_4.0_0.6B
# HAS_TEXT_VLLM_EXTRA_ARGS=--dtype bfloat16 --max-model-len 8192 --gpu-memory-utilization 0.22
#
# GLM VLM uses the Windows CUDA llama.cpp binary:
# GLM_FLASH_ENABLED=1
# GLM_FLASH_SERVER_BIN=D:\path\to\llama-server.exe
# GLM_FLASH_MODEL_FOR_SERVER=D:\path\to\GLM-4.6V-Flash-Q4_K_M.gguf
# GLM_FLASH_MMPROJ_FOR_SERVER=D:\path\to\mmproj-F16.gguf

# ---------- Timeouts in seconds ----------
# OCR_TIMEOUT=360
# HAS_TIMEOUT=120
# HAS_IMAGE_TIMEOUT=120

# ---------- PaddleOCR device ----------
# OCR_REQUIRE_GPU=false              # Reject CPU fallback instead of running slowly
# Enable GPU services with:
# docker compose --profile gpu up -d

# ---------- CORS ----------
# CORS_ORIGINS=["http://localhost:3000"]   # JSON array format
# Production example:
# CORS_ORIGINS=["https://your-domain.com"]
# Multiple origins example:
# CORS_ORIGINS=["https://app.example.com","https://admin.example.com"]
# WARNING: do not use ["*"] in production.

# ---------- Optional security ----------
# PRODUCTION WARNING: enable encryption and virus scanning for sensitive data.
# FILE_ENCRYPTION_ENABLED=false      # AES-256-GCM at-rest encryption
# VIRUS_SCAN_ENABLED=false           # Requires a ClamAV daemon

# ---------- Redaction ----------
# DEFAULT_REPLACEMENT_MODE=smart     # smart / mask / custom
