# ============================================================
# DataInfra-RedactionEverything local development environment variables
# Copy this file to .env when using npm run setup/dev/doctor.
# For Docker Compose, copy .env.docker.example instead.
# ============================================================

# ---------- Basics ----------
DEBUG=true                           # true / false
# APP_NAME=DataShield Redaction Infrastructure

# ---------- Authentication ----------
# PRODUCTION WARNING: keep AUTH_ENABLED=true for any shared or non-local deployment.
AUTH_ENABLED=false                   # Local-only default; eval scripts do not need token env vars in this mode
# Local eval/automation can authenticate with one of these without storing
# browser cookies. Never commit real values.
# DATAINFRA_PASSWORD=
# DATAINFRA_TOKEN=
# DATAINFRA_TOKEN_FILE=
# JWT_SECRET_KEY=                    # Leave empty to auto-generate and persist under DATA_DIR
# NOTE (Windows): for production, prefer an explicit environment variable instead
# of relying on a file-persisted secret.
# JWT_EXPIRE_MINUTES=1440            # Token lifetime in minutes (default: 24h)

# ---------- Local directories ----------
# Relative paths are resolved from backend/ when using npm run dev.
DATA_DIR=./data
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs

# ---------- File limits ----------
# MAX_FILE_SIZE=52428800             # Maximum upload size in bytes (default: 50 MB)

# ---------- Service endpoints ----------
# Local development (without Docker):
OCR_BASE_URL=http://127.0.0.1:8082
HAS_LLAMACPP_BASE_URL=http://127.0.0.1:8080/v1
HAS_IMAGE_BASE_URL=http://127.0.0.1:8081

# ---------- Local npm-run development ----------
# These are used by `npm run setup`, `npm run dev`, and `npm run doctor`.
# First-failure routing:
# - browser UI/API only: docker compose up -d
# - GPU full stack: docker compose --profile gpu up -d
# - reuse healthy localhost services: npm run dev:attach
# - repair missing local deps/models: npm run setup
# Keep Python environments for Python services only:
# .venv runs the backend, PaddleOCR adapter, and HaS Image;
# .venv-vllm is optional and only runs PaddleOCR-VL through vLLM.
# GGUF models run through an external llama-server binary, not Python wheels.
# VENV_DIR=.venv
# VLLM_VENV_DIR=.venv-vllm
# SETUP_TMPDIR=/tmp/datainfra-redaction-setup
# PYTHON_INCLUDE_DIR=/opt/datainfra-redaction/python-dev/usr/include/python3.12
# PYTHON_PLATFORM_INCLUDE_DIR=/opt/datainfra-redaction/python-dev/usr/include/x86_64-linux-gnu/python3.12
# BACKEND_PORT=8000
# FRONTEND_PORT=3000
# HAS_TEXT_PORT=8080
# HAS_IMAGE_PORT=8081
# OCR_PORT=8082
# OCR_VLLM_PORT=8118
# User entry note:
# Only FRONTEND_PORT (default 3000) should be opened in a browser.
# Backend/model ports are service endpoints for API checks and model calls.
# Model download and path setup: docs/MODELS.md
# HAS_MODEL_PATH=/mnt/d/has_models/HaS_Text_0209_0.6B_Q4_K_M.gguf
# HAS_TEXT_N_CTX=8192
# HAS_TEXT_N_GPU_LAYERS=-1
# Optional: use an external llama-server instead of the Python llama-cpp server.
# This avoids mixing HaS Text CUDA/Vulkan runtime packages into the Paddle/Torch app venv.
# HAS_TEXT_SERVER_BIN=
# HAS_TEXT_MODEL_PATH_FOR_SERVER=
# HAS_TEXT_DEVICE=
# Optional: run HaS Text from a Hugging Face/safetensors checkpoint through vLLM
# instead of the GGUF llama-server path. This is useful for the 0.6B BF16 model,
# but on 16GB GPUs it should replace the Q4 server, not run beside it.
# HAS_TEXT_RUNTIME=vllm
# HAS_TEXT_HF_MODEL_PATH=/mnt/d/has_models/hf-cache/hub/models--xuanwulab--HaS_4.0_0.6B/snapshots/<revision>
# HAS_TEXT_MODEL_NAME=HaS_4.0_0.6B
# HAS_TEXT_VLLM_EXTRA_ARGS=--dtype bfloat16 --max-model-len 8192 --max-num-batched-tokens 8192 --gpu-memory-utilization 0.22 --no-enable-prefix-caching --enforce-eager
# HAS_IMAGE_WEIGHTS=/mnt/d/has_models/sensitive_seg_best.pt
# Optional GLM-4.6V-Flash VLM service. It is disabled unless GLM_FLASH_ENABLED=1.
# Prefer a CUDA llama.cpp build for this service; avoid the Winget Vulkan binary
# when an NVIDIA CUDA build is available.
# GLM_FLASH_ENABLED=0
# GLM_FLASH_PORT=8090
# GLM_FLASH_SERVER_BIN=/mnt/d/llama.cpp/llama-server.exe
# GLM_FLASH_MODEL_FOR_SERVER=D:/has_models/GLM-4.6V-Flash-Q4_K_M.gguf
# GLM_FLASH_MMPROJ_FOR_SERVER=D:/has_models/mmproj-F16.gguf
# GLM_FLASH_ALIAS=GLM-4.6V-Flash-Q4
# GLM_FLASH_DEVICE=CUDA0
# GLM_FLASH_N_GPU_LAYERS=auto
# GLM_FLASH_N_CTX=2048
# GLM_FLASH_N_PARALLEL=1
# GLM_FLASH_CACHE_TYPE_K=q8_0
# GLM_FLASH_CACHE_TYPE_V=q8_0
# GLM_FLASH_MMPROJ_OFFLOAD=1
# GLM_FLASH_START_DELAY_SEC=75
# VLM_BASE_URL=http://127.0.0.1:8090
# VLM_MODEL_NAME=GLM-4.6V-Flash-Q4
# VLM_TIMEOUT=35
# VLM_MAX_IMAGE_SIDE=640
# PADDLE_INDEX_URL=https://www.paddlepaddle.org.cn/packages/stable/cu129/
# VLLM_SPEC=vllm==0.19.1
# VLLM_TORCH_BACKEND=cu129
# 16GB all-GPU profile: keep GLM, HaS Text, HaS Image, and PaddleOCR-VL on GPU
# while limiting PaddleOCR-VL cache memory.
# VLLM_EXTRA_ARGS=--max-model-len 4096 --max-num-batched-tokens 1024 --gpu-memory-utilization 0.34 --no-enable-prefix-caching --mm-processor-cache-gb 0 --enforce-eager --attention-backend TRITON_ATTN --mm-encoder-attn-backend TORCH_SDPA

# ---------- Timeouts in seconds ----------
# OCR_TIMEOUT=360
# OCR_MAX_NEW_TOKENS=1024              # Lower to 512 for speed, raise for dense scanned pages
# HAS_TIMEOUT=120
# HAS_NER_MAX_TOKENS=1024              # Upper bound for each HaS Text NER response
# HAS_NER_MAX_TYPES_PER_REQUEST=12     # Built-in text schema labels per HaS Text NER request
# HAS_NER_CUSTOM_MAX_TYPES_PER_REQUEST=4 # Custom labels per HaS Text NER request
# HAS_NER_CACHE_TTL_SEC=300            # Set 0 to disable HaS Text NER result cache
# HAS_NER_CACHE_MAX_ITEMS=256          # Set 0 to disable HaS Text NER result cache
# OCR_TEXT_BLOCK_CACHE_TTL_SEC=300     # Set 0 to disable backend OCR text block cache
# OCR_TEXT_BLOCK_CACHE_MAX_ITEMS=128   # Set 0 to disable backend OCR text block cache
# PDF_PAGE_TEXT_BLOCK_CACHE_PAGES=64   # Set 0 to disable native PDF text-layer coordinate cache
# HAS_VISION_MAX_TEXT_CHARS=500000     # Keep high by default; lower only after recall checks
# HAS_VISION_MIN_TEXT_CHARS_FOR_NER=1  # Raise only to skip very short OCR pages after recall checks
# HAS_IMAGE_TIMEOUT=120
# BATCH_RECOGNITION_PAGE_TIMEOUT=180
# BATCH_RECOGNITION_PAGE_CONCURRENCY=1   # Use 2 only after measuring on larger GPUs
# VISION_DUAL_PIPELINE_PARALLEL=true     # Set false only when GPU memory contention is more important than speed

# ---------- Redaction output ----------
# REDACTION_PDF_JPEG_QUALITY=88           # Scanned PDF page raster quality, clamped to 60-95

# ---------- Evaluation gates ----------
# EVAL_BATCH_MIN_FILE_DETECTIONS=1        # Per completed file: entities + bounding boxes
# EVAL_BATCH_MIN_TOTAL_DETECTIONS=        # Default is the input file count
# EVAL_BATCH_MIN_TOTAL_ENTITIES=0
# EVAL_BATCH_MIN_TOTAL_BOXES=0
# EVAL_BATCH_MAX_PDF_SIZE_RATIO=8         # Fail redacted PDFs above original-size multiple
# EVAL_BATCH_MAX_PDF_SIZE_BYTES=20971520  # Fail redacted PDFs above 20 MiB
# EVAL_BATCH_WARN_PDF_SIZE_RATIO=4        # Mark delivery risk above original-size multiple
# EVAL_BATCH_WARN_PDF_SIZE_BYTES=10485760 # Mark delivery risk above 10 MiB
# EVAL_VISION_PAGES=                     # Optional API eval pages, e.g. 1,5 or 1,3-4
# EVAL_VISION_MIN_TOTAL_BOXES=            # Default is the parsed page count
# EVAL_VISION_MIN_PAGE_BOXES=1
# EVAL_VISION_MIN_TOTAL_VISUAL_BOXES=0    # Set to 1+ for seal/visual spot checks
# EVAL_VISION_MIN_PAGE_VISUAL_BOXES=0
# EVAL_VISION_MIN_TOTAL_HAS_IMAGE_BOXES=0 # Set to 1+ to prove HaS Image contributed boxes
# EVAL_VISION_MIN_PAGE_HAS_IMAGE_BOXES=0
# EVAL_VISION_MAX_WARNINGS=-1             # -1 disables warning-count failure
# EVAL_VISION_MAX_PAGE_MS=0               # 0 disables latency failure
# EVAL_VISION_REQUIRE_ALL_ONLINE=false
# EVAL_TEXT_MIN_ENTITIES=1
# EVAL_TEXT_MIN_CONTENT_CHARS=1
# EVAL_TEXT_MAX_WARNINGS=-1              # -1 disables warning-count failure
# EVAL_TEXT_MAX_PARSE_MS=0               # 0 disables parse latency failure
# EVAL_TEXT_MAX_NER_MS=0                 # 0 disables NER latency failure
# EVAL_TEXT_REQUIRE_SEMANTIC_HIT=false   # Fail if semantic types have no HaS/semantic hit
# EVAL_TEXT_DIRECT_TYPES=                # Optional API-free local text/DOCX eval type list
# EVAL_TEXT_DIRECT_MIN_ENTITIES=1
# EVAL_TEXT_DIRECT_MIN_CONTENT_CHARS=1
# EVAL_TEXT_DIRECT_MAX_WARNINGS=-1       # -1 disables warning-count failure
# EVAL_TEXT_DIRECT_MAX_PARSE_MS=0        # 0 disables parse latency failure
# EVAL_TEXT_DIRECT_MAX_NER_MS=0          # 0 disables NER latency failure
# EVAL_TEXT_DIRECT_REQUIRE_SEMANTIC_HIT=false
# EVAL_OCR_MIN_TOTAL_BOXES=              # Default is evaluated page count
# EVAL_OCR_MIN_PAGE_BOXES=1
# EVAL_OCR_MAX_WARNINGS=-1               # -1 disables warning-count failure
# EVAL_OCR_MAX_ERRORS=0
# EVAL_SEAL_MIN_TOTAL_REGIONS=1          # Offline seal fallback must find at least one candidate
# EVAL_SEAL_MIN_PAGE_REGIONS=0           # Keep 0 when not every page is expected to contain a seal
# EVAL_SEAL_MAX_WARNINGS=-1              # -1 keeps seam/corner warnings as review queue only
# EVAL_SEAL_MAX_HIGH_WARNINGS=0          # Fail high-severity over-redaction warnings by default

# ---------- PaddleOCR device ----------
# OCR_REQUIRE_GPU=false              # Reject CPU fallback instead of running slowly
# Enable GPU services with:
# docker compose --profile gpu up -d

# ---------- CORS ----------
# CORS_ORIGINS=["http://localhost:3000"]   # JSON array format
# Production example:
# CORS_ORIGINS=["https://your-domain.com"]
# Multiple origins example:
# CORS_ORIGINS=["https://app.example.com","https://admin.example.com"]
# WARNING: do not use ["*"] in production.

# ---------- Optional security ----------
# PRODUCTION WARNING: enable encryption and virus scanning for sensitive data.
# FILE_ENCRYPTION_ENABLED=false      # AES-256-GCM at-rest encryption
# VIRUS_SCAN_ENABLED=false           # Requires a ClamAV daemon

# ---------- Redaction ----------
# DEFAULT_REPLACEMENT_MODE=smart     # smart / mask / custom
